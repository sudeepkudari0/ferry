<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp">

    <!-- Timeline Line -->
    <View
        android:id="@+id/timelineLine"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#E5E7EB"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="11dp" />

    <!-- Timeline Dot -->
    <View
        android:id="@+id/timelineDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/status_dot_live"
        android:backgroundTint="#9CA3AF"
        app:layout_constraintBottom_toBottomOf="@+id/stepCard"
        app:layout_constraintEnd_toEndOf="@+id/timelineLine"
        app:layout_constraintStart_toStartOf="@+id/timelineLine"
        app:layout_constraintTop_toTopOf="@+id/stepCard" />

    <!-- Step Content Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/stepCard"
        style="@style/Ferry.CardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/card_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/timelineLine"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/stepActionType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLICK"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stepReasoning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tapping on the 'Reply' button to start writing the email."
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/stepTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="10:45:03 AM"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
